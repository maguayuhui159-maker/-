# MySQL root 密码，部署前请改成自己的强密码
MYSQL_ROOT_PASSWORD=change_me_mysql_root_password

# JWT 签名密钥，部署前请改成随机字符串
JWT_SECRET=change_me_jwt_secret
JWT_EXPIRE_MS=86400000

# AI 供应商：openai、deepseek 或 doubao
AI_PROVIDER=openai

# 豆包 / 火山方舟配置
ARK_API_KEY=
DOUBAO_API_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
DOUBAO_MODEL=doubao-seed-1-6-250615

# OpenAI 配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_URL=https://api.openai.com/v1/chat/completions
OPENAI_MODEL=gpt-4o-mini

# 图片生成配置，auto 表示优先使用 OpenAI，失败后自动尝试备用服务
IMAGE_PROVIDER=auto
OPENAI_IMAGE_MODEL=gpt-image-1

# DeepSeek 配置，可作为文本问答备用模型
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat
